programa {
  funcao inicio() {
    real b1, b2, b3, media
    escreva ("Digite um número: ")
    leia (b1)
    escreva ("Digite um segundo número: ")
    leia (b2)
    escreva ("Digite um terceiro número: ")
    leia (b3)
    media = (b1 + b2 + b3) /3
    escreva ("Essa é a média do seus três números: ", media)
  }
}